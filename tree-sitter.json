{
  "reference": "master",
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Cisco configuration parser for tree-sitter",
    "authors": [
      {
        "name": "Francesco Rubeo"
      }
    ],
    "keywords": [
      "tree-sitter",
      "cisco",
      "ios",
      "nxos",
      "asa",
      "ios-xe",
      "ios-xr",
      "network",
      "parser",
      "cli"
    ],
    "links": {
      "repository": "https://github.com/Alcarin/Tree-Sitter-Cisco",
      "homepage": "https://github.com/Alcarin/Tree-Sitter-Cisco#readme",
      "bugs": "https://github.com/Alcarin/Tree-Sitter-Cisco/issues"
    }
  },
  "grammars": [
    {
      "name": "cisco",
      "camelcase": "Cisco",
      "scope": "source.cisco",
      "path": ".",
      "file-types": [
        "cfg",
        "conf",
        "ios",
        "nxos",
        "xr",
        "asa"
      ]
    }
  ],
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "java": true,
    "csharp": true,
    "ruby": true,
    "php": true,
    "perl": true
  }
}
